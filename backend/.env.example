PORT=5000
NODE_ENV=development

# Ưu tiên dùng DATABASE_URL khi deploy cloud
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
DB_SSL=true

# Nếu chạy local không dùng DATABASE_URL thì dùng block bên dưới
DB_HOST=localhost
DB_PORT=5432
DB_NAME=BADMINTONHUB
DB_USER=postgres
DB_PASSWORD=your_password

# Có thể set nhiều origin, cách nhau bởi dấu phẩy
# Ví dụ: http://localhost:3000,https://your-frontend-domain.com
CORS_ORIGIN=http://localhost:3000